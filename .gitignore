/dist
# Rust build dirs at any depth. Vendored crates (libs/*/vendored/*) ship their
# own target/, which a root-anchored `/target` missed — #276 committed a stray
# fontcull-read-fonts/target/package/*.crate that way.
target/
.dodeca.db
/docs/public/
public/
.cache/
bloaty_report*
*.mm_profdata

llvm-lines*
perf-*.data
*.zst
*.log
.handoffs

.claude/settings.local.json
dodeca-log.txt

# Browser tests
browser-tests/node_modules/
browser-tests/test-results/
.tracey/

# Wasm build
/target-wasm/
crates/dodeca-devtools/pkg/
crates/dodeca-search-wasm/pkg/
crates/*/target-wasm/
.pnpm-store/
examples/vite-starter/node_modules

.playwright-mcp/
profile.json.gz

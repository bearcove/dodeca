// Aggregator config: the root source (kb) is the top-level `source` mounted at
// /, the wiki is a `mounts` entry at /wiki. Each source's pages must render with
// its OWN page.html, and a shared bare template name like "shell.html" must
// resolve within the rendering source — never the other's.
source {
    content kb/content
}

mounts (
    {
        name wiki
        path /wiki
        local wiki/content
    }
)

site {
    output public
}
